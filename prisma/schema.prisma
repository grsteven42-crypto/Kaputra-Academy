datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  phone         String?
  role          String    @default("STUDENT")
  studentIdStr  String?   @unique // e.g., KPA-2026-0001
  parentId      String?   
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  parent              User?               @relation("ParentChild", fields: [parentId], references: [id])
  children            User[]              @relation("ParentChild")
  enrollments         Enrollment[]
  teachingAssignments TeacherAssignment[]
  verifiedPayments    Payment[]           @relation("PaymentVerifier")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  courses     Course[]
}

model Course {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String
  fullDescription  String   @db.Text
  objectives       String   @db.Text
  learningOutcomes String   @db.Text
  schedule         String
  price            Float
  registrationFee  Float    @default(0)
  thumbnailUrl     String?
  categoryId       String
  isPublished      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  category      Category            @relation(fields: [categoryId], references: [id])
  enrollments   Enrollment[]
  teachers      TeacherAssignment[]
  registrations Registration[]
}

model TeacherAssignment {
  id         String   @id @default(cuid())
  teacherId  String
  courseId   String
  assignedAt DateTime @default(now())

  teacher User   @relation(fields: [teacherId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])

  @@unique([teacherId, courseId])
}

model Registration {
  id                String             @id @default(cuid())
  studentName       String
  studentAge        Int
  parentName        String
  parentPhone       String
  parentEmail       String
  courseId          String
  status            String             @default("PENDING_PAYMENT")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  course            Course             @relation(fields: [courseId], references: [id])
  payment           Payment?
  placementTest     PlacementTest?
}

model Payment {
  id               String        @id @default(cuid())
  registrationId   String        @unique
  amount           Float
  paymentMethod    String?
  receiptUrl       String?       // Support for payment receipt uploads
  status           String        @default("PENDING")
  verifiedById     String?
  verifiedAt       DateTime?
  adminNotes       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  registration     Registration  @relation(fields: [registrationId], references: [id])
  verifiedBy       User?         @relation("PaymentVerifier", fields: [verifiedById], references: [id])
}

model PlacementTest {
  id               String       @id @default(cuid())
  registrationId   String       @unique
  studentIdStr     String       @unique // e.g., KPA-2026-0001
  testCode         String       @unique // e.g., PT-KPA-8X3F9Q
  status           String       @default("NOT_STARTED")
  expiresAt        DateTime?
  startedAt        DateTime?
  submittedAt      DateTime?
  score            Float?
  answers          String?      @db.Text // JSON for multiple choice answers
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  registration     Registration @relation(fields: [registrationId], references: [id])
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  courseId  String
  status    String           @default("ACTIVE")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student   User     @relation(fields: [studentId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

model ContentBlock {
  id        String   @id @default(cuid())
  section   String   @unique // e.g., "hero_slider", "about_us", "contact_info"
  content   String   @db.Text // JSON string payload for CMS content
  updatedAt DateTime @updatedAt
}
